{
  "name": "worganic-monorepo",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "start": "nx serve portail",
    "start:projets": "nx serve projets",
    "start:api": "nx serve api",
    "start:electron": "nx serve electron",
    "start:all": "nx run-many --target=serve --projects=portail,projets,api --parallel",
    "start:full": "nx run-many --target=serve --projects=portail,projets,api,electron --parallel",
    "build": "nx run-many --target=build --projects=portail,projets",
    "build:portail": "nx build portail",
    "build:projets": "nx build projets",
    "affected:build": "nx affected --target=build",
    "test": "nx run-many --target=test --all",
    "lint": "nx run-many --target=lint --all",
    "graph": "nx graph",
    "nx": "nx"
  },
